# =============================================================================
# DeFi Risk Lakehouse — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit secrets.

# ---------------------------------------------------------------------------
# The Graph API
# ---------------------------------------------------------------------------
# Free API key from https://thegraph.com/studio (100K queries/month, no CC)
# If empty, the ingestion clients fall back to the hosted service endpoints
# (which may be rate-limited or deprecated for some subgraphs).
GRAPH_API_KEY=

# ---------------------------------------------------------------------------
# MinIO (S3-compatible storage)
# These match the values in docker-compose.yml; override only if needed.
# ---------------------------------------------------------------------------
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=lakehouse

# ---------------------------------------------------------------------------
# Nessie (Iceberg catalog)
# ---------------------------------------------------------------------------
NESSIE_URI=http://localhost:19120/api/v2

# ---------------------------------------------------------------------------
# Trino
# ---------------------------------------------------------------------------
TRINO_HOST=localhost
TRINO_PORT=8081

# ---------------------------------------------------------------------------
# Airflow
# ---------------------------------------------------------------------------
# Change this in production!
AIRFLOW__WEBSERVER__SECRET_KEY=defi-risk-secret-change-me

# ---------------------------------------------------------------------------
# Spark
# ---------------------------------------------------------------------------
SPARK_MASTER=spark://localhost:7077
